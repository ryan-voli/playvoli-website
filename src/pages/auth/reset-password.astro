---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Redirecting to VOLI App..."
  description="Opening the VOLI app to reset your password."
>
    <main class="card">
        <div class="spinner-wrap">
            <div class="loading-spinner"></div>
        </div>
        <h1 class="title">Redirecting to VOLI App...</h1>
        <p class="subtitle">Opening the VOLI app to reset your password.</p>
        <p class="manual-link">If you're not redirected automatically, <a href="#" id="manual-link">click here</a>.</p>

        <div class="fallback hidden" id="fallback">
            <p class="fallback-title">Don't have the VOLI app installed?</p>
            <p class="fallback-text">Download it from:</p>
            <div class="store-links">
                <a href="https://apps.apple.com/us/app/voli-the-volleyball-hub/id6749812982" class="btn-secondary">App Store</a>
                <a href="https://play.google.com/store/apps/details?id=com.playvoli.app" class="btn-secondary">Google Play</a>
            </div>
            <a href="#" id="open-app-btn" class="btn-primary">Open VOLI App</a>
        </div>
    </main>

    <script is:inline slot="scripts">
        var hash = window.location.hash;
        var appDeepLink = 'voli://auth/reset-password' + hash;

        document.getElementById('manual-link').href = appDeepLink;
        document.getElementById('open-app-btn').href = appDeepLink;

        setTimeout(function() {
            window.location.href = appDeepLink;

            setTimeout(function() {
                document.getElementById('fallback').classList.remove('hidden');
            }, 3000);
        }, 500);
    </script>
</Layout>

<style>
    body {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 5rem 2rem 2rem;
        padding-top: calc(5rem + env(safe-area-inset-top));
        padding-bottom: calc(2rem + env(safe-area-inset-bottom));
    }

    .card {
        width: 100%;
        max-width: 460px;
        background: var(--bg-card);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 3rem 2rem;
        position: relative;
        overflow: hidden;
        text-align: center;
        margin-top: auto;
        margin-bottom: auto;
    }

    .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .spinner-wrap {
        margin-bottom: 1.5rem;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top: 3px solid var(--accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .subtitle {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 1rem;
    }

    .manual-link {
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .manual-link a {
        color: var(--accent);
        text-decoration: none;
    }

    .manual-link a:hover {
        text-decoration: underline;
    }

    .hidden { display: none !important; }

    .fallback {
        margin-top: 1.5rem;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
    }

    .fallback-title {
        color: var(--accent);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .fallback-text {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }

    .store-links {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .btn-primary {
        display: inline-block;
        width: 100%;
        padding: 0.875rem 2.5rem;
        background: var(--accent);
        color: #000;
        font-family: inherit;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 24px var(--accent-glow);
        text-decoration: none;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px var(--accent-glow);
    }

    .btn-secondary {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        background: transparent;
        color: var(--electric-blue);
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 600;
        border: 1px solid var(--electric-blue);
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-secondary:hover {
        background: rgba(0, 212, 255, 0.1);
    }

    @media (max-width: 480px) {
        body { padding: 6rem 1rem 1rem; }
        .card { padding: 2rem 1.5rem; border-radius: 20px; }
        .title { font-size: 1.25rem; }
    }
</style>
