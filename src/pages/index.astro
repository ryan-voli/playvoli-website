---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="VOLI - The Volleyball Hub"
  activePage="home"
  ogUrl="https://playvoli.com/"
>
    <section class="hero">
        <div class="hero-announcement" role="status" aria-label="Announcement">
            <span class="hero-announcement-dot" aria-hidden="true"></span>
            <strong>Update</strong>
            <span>NCAA Women's Fantasy Volleyball — Coming for the 2026 Season</span>
        </div>
        <img src="/images/appicon.webp" alt="VOLI" class="hero-logo">
        <h1 class="hero-title">VOLI: The Volleyball Hub</h1>
        <p class="hero-tagline">Fantasy. Stats. Community.</p>

        <div class="hero-stars">
            <svg viewBox="0 0 24 24" fill="var(--accent)" width="18" height="18"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg viewBox="0 0 24 24" fill="var(--accent)" width="18" height="18"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg viewBox="0 0 24 24" fill="var(--accent)" width="18" height="18"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg viewBox="0 0 24 24" fill="var(--accent)" width="18" height="18"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg viewBox="0 0 24 24" fill="var(--accent)" width="18" height="18"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>

        <p class="hero-description">Experience volleyball like never before with fantasy leagues, real-time stats, and a community of passionate fans.</p>

        <div class="store-buttons">
            <a href="https://apps.apple.com/us/app/voli-the-volleyball-hub/id6749812982"
               class="btn-store">
                <svg viewBox="0 0 24 24" fill="white" width="28" height="28">
                    <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
                </svg>
                <div class="btn-store-text">
                    <span class="btn-store-label">Download on the</span>
                    <span class="btn-store-name">App Store</span>
                </div>
            </a>

            <a href="https://play.google.com/store/apps/details?id=com.playvoli.app"
               class="btn-store">
                <svg viewBox="0 0 24 24" fill="white" width="28" height="28">
                    <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z"/>
                </svg>
                <div class="btn-store-text">
                    <span class="btn-store-label">Get it on</span>
                    <span class="btn-store-name">Google Play</span>
                </div>
            </a>
        </div>

        <div class="hero-quotes">
            <p>"This app is everything I've been dreaming of since I've gotten into professional volleyball!"</p>
            <p>"It was already so fun to watch volleyball before but now it's a completely new experience watching for your fantasy league. LOVE IT!"</p>
            <p>"This app is gorgeous. Thanks for putting it out there. And so fun!"</p>
            <p>"Y'all are starting something huge that could be a massive growth factor for U.S. volleyball."</p>
        </div>
    </section>

    <section class="screenshots">
        <div class="screenshots-container">
            <div class="screenshot-wrapper">
                <img src="/images/screenshots/ss2.png" alt="VOLI App Screenshot" class="screenshot">
            </div>
            <div class="screenshot-wrapper">
                <img src="/images/screenshots/ss1.png" alt="VOLI App Screenshot" class="screenshot">
            </div>
            <div class="screenshot-wrapper">
                <img src="/images/screenshots/ss3.png" alt="VOLI App Screenshot" class="screenshot">
            </div>
        </div>
    </section>

    <section class="features">
        <div class="features-grid">
            <div class="feature-card">
                <img src="/images/icons/fantasy_opt.png" alt="Fantasy" class="feature-icon">
                <h3 class="feature-title">Fantasy</h3>
                <p class="feature-description">Build your dream team with our contract-based fantasy system designed specifically for volleyball.</p>
            </div>
            <div class="feature-card">
                <img src="/images/icons/statistics_opt.png" alt="Stats" class="feature-icon">
                <h3 class="feature-title">Stats</h3>
                <p class="feature-description">More in-depth real-time statistics than anywhere else. Track every dig, kill, and ace.</p>
            </div>
            <div class="feature-card">
                <img src="/images/icons/games_opt.png" alt="Games" class="feature-icon">
                <h3 class="feature-title">Games</h3>
                <p class="feature-description">Live scores, play-by-plays, and detailed information for every professional match.</p>
            </div>
            <div class="feature-card">
                <img src="/images/icons/content_opt.png" alt="Content" class="feature-icon">
                <h3 class="feature-title">Content</h3>
                <p class="feature-description">Podcasts, articles, and exclusive volleyball content all in one place.</p>
            </div>
            <div class="feature-card">
                <img src="/images/icons/community_opt.png" alt="Community" class="feature-icon">
                <h3 class="feature-title">Community</h3>
                <p class="feature-description">Connect with passionate volleyball fans in real-time chat rooms during every game.</p>
            </div>
            <a href="/about" class="feature-card">
                <svg class="learn-more-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/>
                    <path d="M12 5l7 7-7 7"/>
                </svg>
                <h3 class="feature-title">Learn More</h3>
                <p class="feature-description">Find out more about VOLI and our mission to revolutionize volleyball.</p>
            </a>
        </div>
    </section>

    <section class="leagues">
        <p class="leagues-label">Leagues We Cover</p>
        <div class="leagues-logos">
            <a href="https://provolleyball.com" target="_blank"><img src="/images/MLV_opt.webp" alt="MLV" class="league-logo"></a>
            <a href="https://lovb.com" target="_blank"><img src="/images/LOVB_opt.webp" alt="LOVB" class="league-logo"></a>
            <a href="https://www.ncaa.com/sports/volleyball-women" target="_blank"><img src="/images/NCAA_opt.webp" alt="NCAA" class="league-logo"></a>
        </div>
        <p class="leagues-disclaimer">VOLI is an independent fan platform, not affiliated with or endorsed by these leagues.</p>
    </section>

    <section class="contact-bar">
        <p>Have questions or feedback?</p>
        <a href="/contact" class="contact-btn">Contact Us</a>
    </section>
</Layout>

<style>
    /* Hero Section */
    .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 6rem 2rem 4rem;
        padding-top: calc(6rem + env(safe-area-inset-top));
        text-align: center;
    }

    .hero-quotes {
        display: flex;
        gap: 2rem;
        max-width: 1100px;
        margin-top: 3rem;
        padding: 0 1rem;
    }

    .hero-quotes p {
        font-size: 0.8rem;
        font-style: italic;
        color: var(--text-muted);
        line-height: 1.5;
        flex: 1;
    }

    .hero-stars {
        display: flex;
        gap: 0.25rem;
        margin-bottom: 1rem;
    }

    .hero-announcement {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.55rem 1.15rem 0.55rem 0.9rem;
        margin-bottom: 2rem;
        background: linear-gradient(135deg, rgba(200, 255, 0, 0.12), rgba(0, 212, 255, 0.08));
        border: 1px solid rgba(200, 255, 0, 0.35);
        border-radius: 100px;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        box-shadow: 0 0 24px rgba(200, 255, 0, 0.15);
        animation: heroAnnouncementGlow 3s ease-in-out infinite;
        max-width: 100%;
    }

    .hero-announcement-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 12px var(--accent);
        animation: heroAnnouncementDot 1.6s ease-in-out infinite;
        flex-shrink: 0;
    }

    .hero-announcement strong {
        color: var(--accent);
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        white-space: nowrap;
    }

    .hero-announcement > span:last-child {
        color: var(--text-primary);
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: -0.01em;
    }

    @keyframes heroAnnouncementGlow {
        0%, 100% { box-shadow: 0 0 24px rgba(200, 255, 0, 0.15); }
        50% { box-shadow: 0 0 36px rgba(200, 255, 0, 0.32); }
    }

    @keyframes heroAnnouncementDot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.55; transform: scale(0.8); }
    }

    .hero-logo {
        width: 100px;
        height: auto;
        border-radius: 22px;
        margin-bottom: 1.5rem;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #ffffff 0%, rgba(255, 255, 255, 0.8) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-tagline {
        font-size: 1.5rem;
        font-weight: 400;
        color: var(--text-secondary);
        margin-bottom: 1rem;
    }

    .hero-description {
        font-size: 1.1rem;
        color: var(--text-muted);
        max-width: 500px;
        line-height: 1.6;
        margin-bottom: 3rem;
    }

    /* Store buttons */
    .store-buttons {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        width: 100%;
        max-width: 600px;
    }

    .btn-store {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1rem 1.5rem;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .btn-store:hover {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.15);
        transform: translateY(-2px);
    }

    .btn-store svg {
        width: 28px;
        height: 28px;
        flex-shrink: 0;
    }

    .btn-store-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: left;
    }

    .btn-store-label {
        font-size: 0.65rem;
        font-weight: 400;
        color: white;
        opacity: 0.7;
    }

    .btn-store-name {
        font-size: 1rem;
        font-weight: 600;
        color: white;
        line-height: 1;
        margin-top: 2px;
    }

    /* Screenshots Section */
    .screenshots {
        padding: 2rem 2rem 4rem;
        overflow: hidden;
    }

    .screenshots-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .screenshot-wrapper {
        flex: 1;
        max-width: 280px;
    }

    .screenshot-wrapper:nth-child(2) {
        transform: scale(1.1);
        z-index: 2;
    }

    .screenshot {
        width: 100%;
        height: auto;
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    }

    /* Features Section */
    .features {
        padding: 4rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        align-items: stretch;
    }

    .features-grid > * {
        height: 100%;
    }

    .feature-card {
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 2rem;
        position: relative;
        overflow: hidden;
        text-decoration: none;
        display: flex;
        flex-direction: column;
    }

    .feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .feature-icon {
        width: 32px;
        height: 32px;
        margin-bottom: 0.75rem;
        object-fit: contain;
    }

    .feature-title {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
    }

    .feature-description {
        color: var(--text-secondary);
        font-size: 0.95rem;
        line-height: 1.5;
    }

    a.feature-card:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.12);
    }

    .feature-card .learn-more-icon {
        width: 32px;
        height: 32px;
        margin-bottom: 0.75rem;
        color: var(--accent);
    }

    /* Leagues Section */
    .leagues {
        padding: 3rem 2rem;
        text-align: center;
    }

    .leagues-label {
        color: var(--text-muted);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.5rem;
    }

    .leagues-logos {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .league-logo {
        height: 60px;
        width: auto;
        opacity: 0.7;
        transition: opacity 0.2s;
    }

    .league-logo:hover {
        opacity: 1;
    }

    .leagues-disclaimer {
        margin-top: 1.25rem;
        color: var(--text-muted);
        font-size: 0.7rem;
        opacity: 0.6;
    }

    /* Contact Bar */
    .contact-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        padding: 2rem;
        background: var(--bg-card);
        border-top: 1px solid var(--glass-border);
        border-bottom: 1px solid var(--glass-border);
    }

    .contact-bar p {
        color: var(--text-secondary);
        font-size: 1rem;
    }

    .contact-btn {
        padding: 0.75rem 1.5rem;
        background: transparent;
        border: 1px solid var(--accent);
        border-radius: 100px;
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s;
    }

    .contact-btn:hover {
        background: var(--accent);
        color: #000;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero-quotes { display: none; }
        .hero-title { font-size: 2.5rem; }
        .hero-tagline { font-size: 1.25rem; }
        .hero-description { font-size: 1rem; }
        .screenshots-container { gap: 1rem; }
        .screenshot-wrapper { max-width: 180px; }
        .screenshot { border-radius: 16px; }
    }

    @media (max-width: 480px) {
        .hero {
            padding: 5rem 1.5rem 3rem;
        }

        .hero-announcement {
            flex-wrap: wrap;
            justify-content: center;
            row-gap: 0.25rem;
            padding: 0.55rem 1rem 0.55rem 0.85rem;
        }
        .hero-announcement > span:last-child { font-size: 0.78rem; }
        .hero-announcement strong { font-size: 0.65rem; }

        .hero-logo { width: 80px; }
        .hero-title { font-size: 2rem; }
        .hero-tagline { font-size: 1.1rem; }

        .store-buttons { gap: 0.75rem; }
        .btn-store {
            padding: 0.75rem 0.5rem;
            gap: 0.5rem;
        }
        .btn-store svg { width: 22px; height: 22px; }
        .btn-store-label { font-size: 0.55rem; }
        .btn-store-name { font-size: 0.85rem; }

        .screenshots { padding: 2rem 0; }
        .screenshots-container {
            gap: 0.75rem;
            width: 130%;
            margin-left: -15%;
        }
        .screenshot-wrapper {
            max-width: 160px;
            flex-shrink: 0;
        }
        .screenshot { border-radius: 16px; }

        .features { padding: 2rem 1rem; }
        .features-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.75rem;
        }
        .feature-card {
            padding: 1rem;
            border-radius: 14px;
        }
        .feature-icon, .feature-card .learn-more-icon {
            width: 24px;
            height: 24px;
            margin-bottom: 0.5rem;
        }
        .feature-title {
            font-size: 0.9rem;
            margin-bottom: 0.25rem;
        }
        .feature-description {
            font-size: 0.7rem;
            line-height: 1.3;
        }

        .contact-bar {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }
    }
</style>
