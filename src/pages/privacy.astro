---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Privacy Policy - VOLI"
  description="VOLI's Privacy Policy - How we collect, use, and protect your information."
  minimalFooter
>
    <main class="card">
        <h1 class="title">Privacy Policy</h1>
        <p class="subtitle" id="privacy-last-updated">Last updated: Loading...</p>

        <div class="content" id="privacy-content">
            <p>Loading privacy policy...</p>
        </div>
    </main>

    <script is:inline slot="scripts">
        var SUPABASE_URL = 'https://api.playvoli.com';
        var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhjaG9sa3JqcHV6YWhxdW1hamVyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDQ0MDcwMzQsImV4cCI6MjA1OTk4MzAzNH0.RVhKzZkLxwwtbow3i3tUSVVnG_hMl-q0bwuvmqNuDq0';

        (async function() {
            var container = document.getElementById('privacy-content');
            if (!container) return;

            try {
                var response = await fetch(SUPABASE_URL + '/rest/v1/global_settings?select=privacy_policy&limit=1', {
                    headers: {
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
                    }
                });

                if (!response.ok) throw new Error('Failed to fetch privacy policy');

                var data = await response.json();
                if (data && data.length > 0 && data[0].privacy_policy) {
                    renderPrivacyPolicy(data[0].privacy_policy, container);
                } else {
                    container.innerHTML = '<p style="color: var(--text-secondary);">No privacy policy available.</p>';
                }
            } catch (error) {
                console.error('[Privacy] Error:', error);
                container.innerHTML = '<p style="color: var(--text-secondary);">Unable to load privacy policy. Please try again later.</p>';
            }
        })();

        function renderPrivacyPolicy(privacyData, container) {
            var header = privacyData.header;
            var lastUpdated = privacyData.last_updated;
            var sections = privacyData.sections;

            var lastUpdatedEl = document.getElementById('privacy-last-updated');
            if (lastUpdatedEl) lastUpdatedEl.textContent = 'Last updated: ' + lastUpdated;

            var html = '<div style="margin-bottom: 3rem;"><p>' + header + '</p></div>';

            sections.forEach(function(section) {
                html += '<div style="margin-bottom: 3rem;">';
                html += '<div style="color: var(--electric-blue); font-size: 0.8rem; font-weight: 400; margin-bottom: 1rem; text-transform: uppercase; letter-spacing: 0.5px;">' + section.section_number + '. ' + section.section_title + '</div>';

                section.content.forEach(function(item) {
                    if (item.title) {
                        html += '<h3 style="margin-bottom: 0.5rem; font-size: 1rem; color: var(--text-primary);">' + item.title + '</h3>';
                    }

                    if (item.text.indexOf('\u2022') !== -1) {
                        var parts = item.text.split('\u2022');
                        if (parts[0].trim()) {
                            html += '<p>' + parts[0].trim() + '</p>';
                        }
                        if (parts.length > 1) {
                            html += '<ul style="margin-bottom: 1rem; padding-left: 1.5rem; color: var(--text-secondary);">';
                            for (var i = 1; i < parts.length; i++) {
                                html += '<li>' + parts[i].trim() + '</li>';
                            }
                            html += '</ul>';
                        }
                    } else {
                        html += '<p>' + item.text + '</p>';
                    }
                });

                html += '</div>';
            });

            container.innerHTML = html;
        }
    </script>
</Layout>

<style>
    body {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 5rem 2rem 2rem;
        padding-top: calc(5rem + env(safe-area-inset-top));
    }

    .card {
        width: 100%;
        max-width: 800px;
        background: var(--bg-card);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 3rem 2rem;
        position: relative;
        overflow: hidden;
        margin-top: 1rem;
    }

    .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .title {
        font-size: 1.75rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .subtitle {
        font-size: 0.95rem;
        font-weight: 400;
        text-align: center;
        color: var(--text-secondary);
        margin-bottom: 2rem;
    }

    .content {
        text-align: left;
        line-height: 1.8;
        color: var(--text-secondary);
    }

    .content :global(h2), .content :global(h3) {
        color: var(--text-primary);
        margin-top: 2rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .content :global(h2) { font-size: 1.25rem; }
    .content :global(h3) { font-size: 1.1rem; }
    .content :global(p) { margin-bottom: 1rem; }

    .content :global(ul), .content :global(ol) {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
    }

    .content :global(li) { margin-bottom: 0.5rem; }

    .content :global(a) {
        color: var(--accent);
        text-decoration: none;
    }

    .content :global(a:hover) { text-decoration: underline; }

    @media (max-width: 480px) {
        body { padding: 6rem 1rem 1rem; }
        .card { padding: 2rem 1.5rem; border-radius: 20px; }
        .title { font-size: 1.5rem; }
    }
</style>
