---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Terms of Use - VOLI"
  description="VOLI's Terms of Use - Rules and guidelines for using our platform."
  minimalFooter
>
    <main class="card">
        <h1 class="title">Terms of Use</h1>
        <p class="subtitle" id="terms-effective-date">Effective Date: Loading...</p>
        <p class="subtitle last" id="terms-last-updated">Last Updated: Loading...</p>

        <div class="content" id="terms-content">
            <p>Loading terms of use...</p>
        </div>
    </main>

    <script is:inline slot="scripts">
        var SUPABASE_URL = 'https://api.playvoli.com';
        var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhjaG9sa3JqcHV6YWhxdW1hamVyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDQ0MDcwMzQsImV4cCI6MjA1OTk4MzAzNH0.RVhKzZkLxwwtbow3i3tUSVVnG_hMl-q0bwuvmqNuDq0';

        (async function() {
            var container = document.getElementById('terms-content');
            if (!container) return;

            try {
                var response = await fetch(SUPABASE_URL + '/rest/v1/global_settings?select=terms_of_use&limit=1', {
                    headers: {
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY
                    }
                });

                if (!response.ok) throw new Error('Failed to fetch terms of use');

                var data = await response.json();
                if (data && data.length > 0 && data[0].terms_of_use) {
                    renderTermsOfUse(data[0].terms_of_use, container);
                } else {
                    container.innerHTML = '<p style="color: var(--text-secondary);">No terms of use available.</p>';
                }
            } catch (error) {
                console.error('[Terms] Error:', error);
                container.innerHTML = '<p style="color: var(--text-secondary);">Unable to load terms of use. Please try again later.</p>';
            }
        })();

        function renderTermsOfUse(termsData, container) {
            var header = termsData.header;
            var effectiveDate = termsData.effective_date;
            var lastUpdated = termsData.last_updated;
            var sections = termsData.sections;

            var effectiveDateEl = document.getElementById('terms-effective-date');
            var lastUpdatedEl = document.getElementById('terms-last-updated');
            if (effectiveDateEl) effectiveDateEl.textContent = 'Effective Date: ' + effectiveDate;
            if (lastUpdatedEl) lastUpdatedEl.textContent = 'Last Updated: ' + lastUpdated;

            var html = '<p style="margin-bottom: 2rem;">' + header + '</p>';

            sections.forEach(function(section) {
                html += '<h2 style="color: var(--electric-blue); font-size: 1.2rem; margin: 2rem 0 1rem 0;">' + section.section_number + '. ' + section.section_title + '</h2>';

                section.content.forEach(function(item) {
                    if (item.subsection) {
                        html += '<p><strong>' + item.subsection + ' ' + item.title + '.</strong> ' + item.text + '</p>';
                    } else {
                        html += '<p>' + item.text + '</p>';
                    }
                });
            });

            container.innerHTML = html;
        }
    </script>
</Layout>

<style>
    body {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 5rem 2rem 2rem;
        padding-top: calc(5rem + env(safe-area-inset-top));
    }

    .card {
        width: 100%;
        max-width: 800px;
        background: var(--bg-card);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 3rem 2rem;
        position: relative;
        overflow: hidden;
        margin-top: 1rem;
    }

    .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .title {
        font-size: 1.75rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .subtitle {
        font-size: 0.95rem;
        font-weight: 400;
        text-align: center;
        color: var(--text-secondary);
        margin-bottom: 0.25rem;
    }

    .subtitle.last {
        margin-bottom: 2rem;
    }

    .content {
        text-align: left;
        line-height: 1.8;
        color: var(--text-secondary);
    }

    .content :global(h2), .content :global(h3) {
        color: var(--text-primary);
        margin-top: 2rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .content :global(h2) { font-size: 1.25rem; }
    .content :global(h3) { font-size: 1.1rem; }
    .content :global(p) { margin-bottom: 1rem; }

    .content :global(ul), .content :global(ol) {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
    }

    .content :global(li) { margin-bottom: 0.5rem; }

    .content :global(a) {
        color: var(--accent);
        text-decoration: none;
    }

    .content :global(a:hover) { text-decoration: underline; }

    @media (max-width: 480px) {
        body { padding: 6rem 1rem 1rem; }
        .card { padding: 2rem 1.5rem; border-radius: 20px; }
        .title { font-size: 1.5rem; }
    }
</style>
