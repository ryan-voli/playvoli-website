---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [{ params: { slug: undefined } }];
}
---

<Layout
  title="Daily Grid - VOLI"
  description="Play the Voli Daily Grid — fill a 3x3 grid with volleyball players matching row and column categories."
  ogUrl="https://playvoli.com/dailygrid"
  skipNavAuth
>
    <!-- Loading State -->
    <div id="loading-state">
        <div class="loading-spinner"></div>
    </div>

    <!-- Not Signed In -->
    <div id="signin-prompt" class="content hidden">
        <h1 class="page-title">Daily Grid</h1>
        <p class="page-subtitle">Sign in to play today's grid</p>
        <a href="/auth?redirect=/dailygrid" class="btn-signin">Sign In</a>
    </div>

    <!-- Game Container (shown when logged in) -->
    <div id="game-container" class="content hidden">
        <h2 class="page-title">Daily Grid</h2>
        <p class="page-subtitle">Coming soon...</p>
    </div>

    <script is:inline slot="scripts">
        // ── Supabase Init ──
        var SUPABASE_URL = 'https://api.playvoli.com';
        var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhjaG9sa3JqcHV6YWhxdW1hamVyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDQ0MDcwMzQsImV4cCI6MjA1OTk4MzAzNH0.RVhKzZkLxwwtbow3i3tUSVVnG_hMl-q0bwuvmqNuDq0';
        var sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

        var $loading = document.getElementById('loading-state');
        var $signinPrompt = document.getElementById('signin-prompt');
        var $gameContainer = document.getElementById('game-container');
        var $navAuth = document.getElementById('nav-auth');

        async function init() {
            var res = await sb.auth.getSession();
            var session = res.data.session;

            if (session) {
                showGame(session.user);
            } else {
                showSigninPrompt();
            }

            sb.auth.onAuthStateChange(function(event, session) {
                if (event === 'SIGNED_IN' && session) {
                    showGame(session.user);
                } else if (event === 'SIGNED_OUT') {
                    showSigninPrompt();
                }
            });
        }

        function renderNavAuth(user) {
            if (!$navAuth) return;
            if (!user) {
                $navAuth.innerHTML = '<a class="nav-login-link" href="/auth?redirect=/dailygrid">Log In</a>';
                return;
            }
            var avatarUrl = user.user_metadata && user.user_metadata.avatar_url;
            var html = '<div class="nav-avatar-wrap">';
            if (avatarUrl) {
                html += '<img class="nav-avatar" src="' + escapeAttr(avatarUrl) + '" alt="Avatar" onclick="toggleAvatarDropdown(event)">';
            } else {
                html += '<div class="nav-avatar-fallback" onclick="toggleAvatarDropdown(event)">' +
                    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c8ff00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                    '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>' +
                    '<circle cx="12" cy="7" r="4"/></svg></div>';
            }
            html += '<div class="avatar-dropdown" id="avatar-dropdown">' +
                '<button onclick="handleLogout()">Log Out</button></div></div>';
            $navAuth.innerHTML = html;
        }

        function toggleAvatarDropdown(e) {
            e.stopPropagation();
            var dd = document.getElementById('avatar-dropdown');
            if (dd) dd.classList.toggle('open');
        }

        document.addEventListener('click', function() {
            var dd = document.getElementById('avatar-dropdown');
            if (dd) dd.classList.remove('open');
        });

        function showSigninPrompt() {
            $loading.classList.add('hidden');
            $gameContainer.classList.add('hidden');
            $signinPrompt.classList.remove('hidden');
            renderNavAuth(null);
        }

        function showGame(user) {
            $loading.classList.add('hidden');
            $signinPrompt.classList.add('hidden');
            $gameContainer.classList.remove('hidden');
            renderNavAuth(user);
        }

        async function handleLogout() {
            await sb.auth.signOut();
        }

        function escapeAttr(str) {
            return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        init();
    </script>
</Layout>

<style>
    body {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 5rem 2rem 2rem;
        padding-top: calc(5rem + env(safe-area-inset-top));
        padding-bottom: calc(2rem + env(safe-area-inset-bottom));
        overflow-x: hidden;
    }

    .content {
        width: 100%;
        max-width: 500px;
        text-align: center;
        margin-top: auto;
        margin-bottom: auto;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .page-subtitle {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 2rem;
    }

    .btn-signin {
        display: inline-block;
        padding: 0.875rem 2.5rem;
        background: var(--accent);
        color: #000;
        font-family: inherit;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 24px var(--accent-glow);
        text-decoration: none;
    }

    .btn-signin:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px var(--accent-glow);
    }

    .hidden { display: none !important; }

    .loading-spinner {
        width: 32px;
        height: 32px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top: 3px solid var(--accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 4rem auto;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    @media (max-width: 480px) {
        body { padding: 6rem 1rem 1rem; }
    }
</style>
