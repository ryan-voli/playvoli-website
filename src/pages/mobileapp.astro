---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Mobile App - VOLI"
  description="Download the Voli mobile app for iOS and Android. Fantasy volleyball, live stats, community chat, and more."
  ogUrl="https://playvoli.com/mobileapp"
>
    <main class="card">
        <img src="/images/appicon_sm.webp" alt="VOLI" class="app-icon">
        <h1 class="title">Voli Mobile App</h1>
        <p class="subtitle">Our first product — launched January 2026.</p>

        <div class="store-buttons">
            <div class="store-col">
                <a href="https://apps.apple.com/us/app/voli-the-volleyball-hub/id6749812982" class="btn-store" target="_blank">
                    <svg viewBox="0 0 24 24" fill="white" width="28" height="28">
                        <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
                    </svg>
                    <div class="btn-store-text">
                        <span class="btn-store-label">Download on the</span>
                        <span class="btn-store-name">App Store</span>
                    </div>
                </a>
                <div class="rating-stars">
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
            </div>
            <div class="store-downloads">
                <span class="store-downloads-num">1.3k+</span>
                <span class="store-downloads-label">downloads</span>
            </div>
            <div class="store-col">
                <a href="https://play.google.com/store/apps/details?id=com.playvoli.app" class="btn-store" target="_blank">
                    <svg viewBox="0 0 24 24" fill="white" width="28" height="28">
                        <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.802 8.99l-2.303 2.303-8.635-8.635z"/>
                    </svg>
                    <div class="btn-store-text">
                        <span class="btn-store-label">Get it on</span>
                        <span class="btn-store-name">Google Play</span>
                    </div>
                </a>
                <div class="rating-stars">
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    <svg viewBox="0 0 24 24" fill="#F0FF1E"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
            </div>
        </div>

        <div class="section">
            <div class="section-label">The Beginning</div>
            <p class="section-text">The Voli mobile app was our first development and the foundation of everything we do. Launched in January 2026, it was built from the ground up by volleyball fans who saw a gap in the sport's digital experience. The app brings together fantasy leagues, real-time stats, live scores, community chat, podcasts, and more — all in one place.</p>
        </div>

        <div class="section">
            <div class="section-label">What's Inside</div>
            <div class="features-list">
                <div class="feature-row">
                    <img src="/images/icons/fantasy_opt.png" alt="" class="feature-icon">
                    <div>
                        <strong>Fantasy</strong>
                        <span>Contract-based fantasy leagues designed specifically for volleyball.</span>
                    </div>
                </div>
                <div class="feature-row">
                    <img src="/images/icons/statistics_opt.png" alt="" class="feature-icon">
                    <div>
                        <strong>Stats</strong>
                        <span>More in-depth real-time statistics than anywhere else.</span>
                    </div>
                </div>
                <div class="feature-row">
                    <img src="/images/icons/games_opt.png" alt="" class="feature-icon">
                    <div>
                        <strong>Games</strong>
                        <span>Live scores, play-by-plays, and detailed match information.</span>
                    </div>
                </div>
                <div class="feature-row">
                    <img src="/images/icons/content_opt.png" alt="" class="feature-icon">
                    <div>
                        <strong>Content</strong>
                        <span>Podcasts, articles, and exclusive volleyball content.</span>
                    </div>
                </div>
                <div class="feature-row">
                    <img src="/images/icons/community_opt.png" alt="" class="feature-icon">
                    <div>
                        <strong>Community</strong>
                        <span>Real-time chat rooms during every game.</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="section">
            <div class="section-label">Voli User Testimonials</div>
            <div class="testimonials">
                <div class="testimonial">
                    <p>"This app is everything I've been dreaming of since I've gotten into professional volleyball!"</p>
                </div>
                <div class="testimonial">
                    <p>"It was already so fun to watch volleyball before but now it's a completely new experience watching for your fantasy league. LOVE IT!"</p>
                </div>
                <div class="testimonial">
                    <p>"I've spent years watching my brothers play fantasy football and basketball while wondering 'when can I do this for my sport?' So thank you!!"</p>
                </div>
                <div class="testimonial">
                    <p>"Between the fantasy draft and more games being televised, the usual drought between NCAA seasons has been much less painful. I'm excited to be able to stay engaged with volleyball."</p>
                </div>
                <div class="testimonial">
                    <p>"I really appreciate how interactive this experience has been, especially how it adds a greater fan experience to people who watch, or are trying to learn more about pro volleyball."</p>
                </div>
                <div class="testimonial">
                    <p>"This app is gorgeous. Thanks for putting it out there. And so fun!"</p>
                </div>
                <div class="testimonial">
                    <p>"Y'all are starting something huge that could be a massive growth factor for U.S. volleyball."</p>
                </div>
                <div class="testimonial">
                    <p>"Thank you for your work and for investing in the growth of the sport. Great app and can't wait to continue to support you guys."</p>
                </div>
                <div class="testimonial">
                    <p>"This app is pretty much as user friendly as it gets. I was trying to find a way to make this happen just so I could participate, so I was so excited when I saw y'all are on it!"</p>
                </div>
                <div class="testimonial">
                    <p>"So impressed with this app and all of your work."</p>
                </div>
            </div>
        </div>

    </main>
</Layout>

<style>
    body {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 5rem 2rem 2rem;
        padding-top: calc(5rem + env(safe-area-inset-top));
    }

    .card {
        width: 100%;
        max-width: 800px;
        background: var(--bg-card);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 3rem 2rem;
        position: relative;
        overflow: hidden;
        margin-top: 1rem;
    }

    .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .app-icon {
        display: block;
        width: 80px;
        height: auto;
        border-radius: 18px;
        margin: 0 auto 1.25rem;
    }

    .title {
        font-size: 1.75rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .subtitle {
        text-align: center;
        color: var(--text-muted);
        font-size: 1rem;
        margin-bottom: 1.5rem;
    }

    .store-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .rating-stars {
        display: flex;
        gap: 2px;
    }

    .rating-stars svg {
        width: 16px;
        height: 16px;
    }


    .section {
        margin-bottom: 2.5rem;
    }

    .section:last-child {
        margin-bottom: 0;
    }

    .section-label {
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-align: center;
        margin-bottom: 1rem;
    }

    .section-text {
        color: var(--text-secondary);
        font-size: 1rem;
        line-height: 1.8;
        text-align: center;
    }

    .features-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .feature-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem 1rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
    }

    .feature-icon {
        width: 28px;
        height: 28px;
        object-fit: contain;
        flex-shrink: 0;
    }

    .feature-row strong {
        color: var(--text-primary);
        font-size: 0.95rem;
        font-weight: 600;
        display: block;
        margin-bottom: 0.1rem;
    }

    .feature-row span {
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .testimonials {
        columns: 2;
        column-gap: 0.75rem;
    }

    .testimonial {
        padding: 1rem 1.25rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        break-inside: avoid;
        margin-bottom: 0.75rem;
    }

    .testimonial p {
        color: var(--text-secondary);
        font-size: 0.85rem;
        line-height: 1.5;
        font-style: italic;
        margin-bottom: 0.5rem;
    }

    .testimonial span {
        color: var(--text-muted);
        font-size: 0.75rem;
    }

    .store-buttons {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 1.25rem;
        margin: 0 auto 2.5rem;
    }

    .store-downloads {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        padding: 1rem 0;
    }

    .store-downloads-num {
        color: var(--text-primary);
        font-size: 1.5rem;
        font-weight: 700;
        line-height: 1.1;
    }

    .store-downloads-label {
        color: var(--text-muted);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .btn-store {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1rem 1.5rem;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 14px;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .btn-store:hover {
        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.15);
        transform: translateY(-2px);
    }

    .btn-store svg {
        width: 28px;
        height: 28px;
        flex-shrink: 0;
    }

    .btn-store-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: left;
    }

    .btn-store-label {
        font-size: 0.65rem;
        font-weight: 400;
        color: white;
        opacity: 0.7;
    }

    .btn-store-name {
        font-size: 1rem;
        font-weight: 600;
        color: white;
        line-height: 1;
        margin-top: 2px;
    }

    @media (max-width: 480px) {
        body { padding: 6rem 1rem 1rem; }
        .card { padding: 2rem 1.5rem; border-radius: 20px; }
        .title { font-size: 1.5rem; }
        .section-text { font-size: 0.95rem; }
        .testimonials { columns: 1; }
        .store-buttons { gap: 0.75rem; flex-wrap: wrap; justify-content: center; }
        .store-downloads { width: 100%; order: -1; padding: 0 0 0.25rem; }
        .btn-store {
            padding: 0.75rem 0.5rem;
            gap: 0.5rem;
        }
        .btn-store svg { width: 22px; height: 22px; }
        .btn-store-label { font-size: 0.55rem; }
        .btn-store-name { font-size: 0.85rem; }
    }
</style>
