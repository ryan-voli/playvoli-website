---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="Sign In - VOLI"
    description="Sign in or create a VOLI account to play Daily Grid and access all features."
    ogUrl="https://playvoli.com/auth"
    activePage="auth"
    skipNavAuth={true}
    bodyClass="auth-body"
>

<!-- Loading State -->
<div id="loading-state">
    <div class="loading-spinner"></div>
</div>

<!-- Auth Card -->
<div id="auth-card" class="auth-card" style="display:none">

    <!-- Main View: Login / Signup -->
    <div id="view-main" class="auth-view active">
        <h1 class="auth-title">Welcome to Voli</h1>
        <p class="auth-subtitle">Sign in or create an account</p>

        <div class="tab-toggle">
            <button id="tab-login" class="active" onclick="switchTab('login')">Log In</button>
            <button id="tab-signup" onclick="switchTab('signup')">Sign Up</button>
        </div>

        <div id="auth-message" class="message"></div>

        <!-- Login Form -->
        <form id="login-form" class="auth-form" onsubmit="handleLogin(event)">
            <input type="email" class="form-input" id="login-email" placeholder="Email" required autocomplete="email">
            <input type="password" class="form-input" id="login-password" placeholder="Password" required autocomplete="current-password">
            <div class="forgot-link">
                <a onclick="showForgotPassword()">Forgot password?</a>
            </div>
            <button type="submit" class="btn-primary" id="login-btn">Log In</button>
        </form>

        <!-- Signup Form -->
        <form id="signup-form" class="auth-form hidden" onsubmit="handleSignup(event)">
            <input type="text" class="form-input" id="signup-username" placeholder="Username" required autocomplete="username" minlength="3" maxlength="20">
            <input type="email" class="form-input" id="signup-email" placeholder="Email" required autocomplete="email">
            <input type="password" class="form-input" id="signup-password" placeholder="Password" required autocomplete="new-password" minlength="8">
            <input type="password" class="form-input" id="signup-confirm" placeholder="Confirm Password" required autocomplete="new-password">
            <button type="submit" class="btn-primary" id="signup-btn">Create Account</button>
        </form>

        <div class="divider"><span>or</span></div>

        <div class="oauth-buttons">
            <button class="btn-oauth" onclick="handleOAuth('google')">
                <svg viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                Continue with Google
            </button>
            <button class="btn-oauth" onclick="handleOAuth('apple')">
                <svg viewBox="0 0 24 24"><path fill="white" d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                Continue with Apple
            </button>
            <button class="btn-oauth" onclick="handleOAuth('discord')">
                <svg viewBox="0 0 24 24"><path fill="#5865F2" d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
                Continue with Discord
            </button>
        </div>
    </div>

    <!-- Forgot Password: Step 1 - Enter Email -->
    <div id="view-forgot-email" class="auth-view">
        <button class="back-link" onclick="showMainView()">&larr; Back to login</button>
        <h1 class="auth-title">Reset Password</h1>
        <p class="auth-subtitle">Enter your email to receive a reset code</p>
        <div id="forgot-message" class="message"></div>
        <form class="auth-form" onsubmit="handleSendResetCode(event)">
            <input type="email" class="form-input" id="forgot-email" placeholder="Email" required autocomplete="email">
            <button type="submit" class="btn-primary" id="forgot-send-btn">Send Code</button>
        </form>
    </div>

    <!-- Forgot Password: Step 2 - Enter Code -->
    <div id="view-forgot-code" class="auth-view">
        <button class="back-link" onclick="showView('view-forgot-email')">&larr; Back</button>
        <h1 class="auth-title">Enter Code</h1>
        <p class="step-hint">We sent a 6-digit code to <strong id="reset-email-display"></strong></p>
        <div id="code-message" class="message"></div>
        <div class="code-inputs" id="code-inputs">
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code">
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
            <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]">
        </div>
        <button class="btn-primary" id="verify-code-btn" onclick="handleVerifyCode()" disabled>Verify Code</button>
        <div class="resend-link"><a onclick="handleResendResetCode()">Resend code</a></div>
    </div>

    <!-- Forgot Password: Step 3 - New Password -->
    <div id="view-forgot-password" class="auth-view">
        <h1 class="auth-title">New Password</h1>
        <p class="auth-subtitle">Choose a strong new password</p>
        <div id="newpw-message" class="message"></div>
        <form class="auth-form" onsubmit="handleSetNewPassword(event)">
            <input type="password" class="form-input" id="new-password" placeholder="New password" required autocomplete="new-password" oninput="checkPasswordRules()">
            <input type="password" class="form-input" id="new-password-confirm" placeholder="Confirm new password" required autocomplete="new-password">
            <div class="password-rules" id="password-rules">
                <span id="rule-length">At least 8 characters</span>
                <span id="rule-upper">At least 1 uppercase letter</span>
                <span id="rule-number">At least 1 number</span>
            </div>
            <button type="submit" class="btn-primary" id="set-password-btn">Set Password</button>
        </form>
    </div>

    <!-- Forgot Password: Step 4 - Success -->
    <div id="view-forgot-success" class="auth-view">
        <div class="success-check">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h1 class="auth-title">Password Updated</h1>
        <p class="auth-subtitle">Your password has been changed. You can now sign in.</p>
        <button class="btn-primary" onclick="showMainView()">Back to Log In</button>
    </div>
</div>

<script is:inline slot="scripts">
    const SUPABASE_URL = 'https://api.playvoli.com';
    const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InhjaG9sa3JqcHV6YWhxdW1hamVyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDQ0MDcwMzQsImV4cCI6MjA1OTk4MzAzNH0.RVhKzZkLxwwtbow3i3tUSVVnG_hMl-q0bwuvmqNuDq0';
    const urlParams = new URLSearchParams(window.location.search);
    const redirectTo = urlParams.get('redirect') || '/';
    const $loading = document.getElementById('loading-state');
    const $authCard = document.getElementById('auth-card');
    let resetEmail = '';
    let sb;

    function showAuth() {
        if ($loading) $loading.style.display = 'none';
        if ($authCard) $authCard.style.display = '';
    }

    try {
        sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
    } catch(e) {
        showAuth();
    }

    async function init() {
        try {
            const { data: { session } } = await sb.auth.getSession();
            if (session) { window.location.href = redirectTo; return; }
        } catch(e) {}
        showAuth();
        sb.auth.onAuthStateChange((event, session) => {
            if (event === 'SIGNED_IN' && session) window.location.href = redirectTo;
        });
    }

    function showView(viewId) {
        document.querySelectorAll('.auth-view').forEach(v => v.classList.remove('active'));
        document.getElementById(viewId).classList.add('active');
    }
    function showMainView() { showView('view-main'); }
    function showForgotPassword() {
        const email = document.getElementById('login-email').value;
        if (email) document.getElementById('forgot-email').value = email;
        showView('view-forgot-email');
    }

    function switchTab(tab) {
        const $loginTab = document.getElementById('tab-login');
        const $signupTab = document.getElementById('tab-signup');
        const $loginForm = document.getElementById('login-form');
        const $signupForm = document.getElementById('signup-form');
        hideMessage('auth-message');
        if (tab === 'login') {
            $loginTab.classList.add('active'); $signupTab.classList.remove('active');
            $loginForm.classList.remove('hidden'); $signupForm.classList.add('hidden');
        } else {
            $signupTab.classList.add('active'); $loginTab.classList.remove('active');
            $signupForm.classList.remove('hidden'); $loginForm.classList.add('hidden');
        }
    }

    function showMessage(id, text, type) {
        const el = document.getElementById(id);
        el.innerHTML = text;
        el.className = 'message ' + type + ' visible';
    }
    function hideMessage(id) {
        const el = document.getElementById(id);
        el.className = 'message';
        el.innerHTML = '';
    }

    async function handleLogin(e) {
        e.preventDefault();
        const email = document.getElementById('login-email').value;
        const password = document.getElementById('login-password').value;
        const btn = document.getElementById('login-btn');
        btn.disabled = true; btn.textContent = 'Signing in...';
        hideMessage('auth-message');
        const { error } = await sb.auth.signInWithPassword({ email, password });
        if (error) {
            const msg = error.message || '';
            if (msg.toLowerCase().includes('email not confirmed') || msg.toLowerCase().includes('not confirmed')) {
                showMessage('auth-message', 'Email not confirmed. Check your inbox or <button class="inline-btn" onclick="handleResendConfirmation(\'' + escapeHtml(email) + '\')">resend confirmation email</button>.', 'error');
            } else {
                showMessage('auth-message', escapeHtml(msg), 'error');
            }
            btn.disabled = false; btn.textContent = 'Log In';
        }
    }

    async function handleResendConfirmation(email) {
        showMessage('auth-message', 'Sending confirmation email...', 'success');
        const { error } = await sb.auth.resend({ type: 'signup', email: email });
        if (error) { showMessage('auth-message', escapeHtml(error.message), 'error'); }
        else { showMessage('auth-message', 'Confirmation email sent! Check your inbox.', 'success'); }
    }

    async function handleSignup(e) {
        e.preventDefault();
        const username = document.getElementById('signup-username').value.trim();
        const email = document.getElementById('signup-email').value;
        const password = document.getElementById('signup-password').value;
        const confirm = document.getElementById('signup-confirm').value;
        const btn = document.getElementById('signup-btn');
        hideMessage('auth-message');
        if (password !== confirm) { showMessage('auth-message', 'Passwords do not match', 'error'); return; }
        if (username.length < 3) { showMessage('auth-message', 'Username must be at least 3 characters', 'error'); return; }
        if (password.length < 8) { showMessage('auth-message', 'Password must be at least 8 characters', 'error'); return; }
        btn.disabled = true; btn.textContent = 'Creating account...';
        const { data, error } = await sb.auth.signUp({ email, password, options: { data: { username } } });
        if (error) { showMessage('auth-message', escapeHtml(error.message), 'error'); btn.disabled = false; btn.textContent = 'Create Account'; return; }
        if (data.user && !data.session) { showMessage('auth-message', 'Check your email for a confirmation link!', 'success'); btn.disabled = false; btn.textContent = 'Create Account'; }
    }

    async function handleSendResetCode(e) {
        e.preventDefault();
        const email = document.getElementById('forgot-email').value;
        const btn = document.getElementById('forgot-send-btn');
        btn.disabled = true; btn.textContent = 'Sending...';
        hideMessage('forgot-message');
        const { error } = await sb.auth.resetPasswordForEmail(email);
        if (error) { showMessage('forgot-message', escapeHtml(error.message), 'error'); btn.disabled = false; btn.textContent = 'Send Code'; return; }
        resetEmail = email;
        document.getElementById('reset-email-display').textContent = email;
        document.querySelectorAll('#code-inputs input').forEach(i => { i.value = ''; });
        document.getElementById('verify-code-btn').disabled = true;
        btn.disabled = false; btn.textContent = 'Send Code';
        showView('view-forgot-code');
    }

    async function handleVerifyCode() {
        const inputs = document.querySelectorAll('#code-inputs input');
        const code = Array.from(inputs).map(i => i.value).join('');
        const btn = document.getElementById('verify-code-btn');
        if (code.length !== 6) return;
        btn.disabled = true; btn.textContent = 'Verifying...';
        hideMessage('code-message');
        const { error } = await sb.auth.verifyOtp({ type: 'recovery', email: resetEmail, token: code });
        if (error) { showMessage('code-message', escapeHtml(error.message), 'error'); btn.disabled = false; btn.textContent = 'Verify Code'; return; }
        btn.disabled = false; btn.textContent = 'Verify Code';
        showView('view-forgot-password');
    }

    async function handleResendResetCode() {
        if (!resetEmail) return;
        hideMessage('code-message');
        const { error } = await sb.auth.resetPasswordForEmail(resetEmail);
        if (error) { showMessage('code-message', escapeHtml(error.message), 'error'); }
        else { showMessage('code-message', 'New code sent!', 'success'); }
    }

    async function handleSetNewPassword(e) {
        e.preventDefault();
        const password = document.getElementById('new-password').value;
        const confirm = document.getElementById('new-password-confirm').value;
        const btn = document.getElementById('set-password-btn');
        hideMessage('newpw-message');
        if (password !== confirm) { showMessage('newpw-message', 'Passwords do not match', 'error'); return; }
        if (password.length < 8 || !/[A-Z]/.test(password) || !/[0-9]/.test(password)) { showMessage('newpw-message', 'Password does not meet requirements', 'error'); return; }
        btn.disabled = true; btn.textContent = 'Updating...';
        const { error } = await sb.auth.updateUser({ password });
        if (error) { showMessage('newpw-message', escapeHtml(error.message), 'error'); btn.disabled = false; btn.textContent = 'Set Password'; return; }
        await sb.auth.signOut({ scope: 'local' });
        btn.disabled = false; btn.textContent = 'Set Password';
        showView('view-forgot-success');
    }

    function checkPasswordRules() {
        const pw = document.getElementById('new-password').value;
        document.getElementById('rule-length').classList.toggle('valid', pw.length >= 8);
        document.getElementById('rule-upper').classList.toggle('valid', /[A-Z]/.test(pw));
        document.getElementById('rule-number').classList.toggle('valid', /[0-9]/.test(pw));
    }

    (function setupCodeInputs() {
        const container = document.getElementById('code-inputs');
        const inputs = container.querySelectorAll('input');
        const verifyBtn = document.getElementById('verify-code-btn');
        function updateVerifyBtn() {
            const code = Array.from(inputs).map(i => i.value).join('');
            verifyBtn.disabled = code.length !== 6;
        }
        inputs.forEach((input, idx) => {
            input.addEventListener('input', (e) => {
                const val = e.target.value.replace(/[^0-9]/g, '');
                e.target.value = val.charAt(0) || '';
                if (val && idx < inputs.length - 1) inputs[idx + 1].focus();
                updateVerifyBtn();
            });
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && idx > 0) {
                    inputs[idx - 1].focus(); inputs[idx - 1].value = '';
                    updateVerifyBtn();
                }
                if (e.key === 'Enter') {
                    e.preventDefault();
                    const code = Array.from(inputs).map(i => i.value).join('');
                    if (code.length === 6) handleVerifyCode();
                }
            });
            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const paste = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '');
                for (let i = 0; i < Math.min(paste.length, 6); i++) inputs[i].value = paste[i];
                inputs[Math.min(paste.length, 5)].focus();
                updateVerifyBtn();
            });
        });
    })();

    async function handleOAuth(provider) {
        hideMessage('auth-message');
        const { error } = await sb.auth.signInWithOAuth({
            provider,
            options: { redirectTo: window.location.origin + '/auth?redirect=' + encodeURIComponent(redirectTo) }
        });
        if (error) showMessage('auth-message', escapeHtml(error.message), 'error');
    }

    function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    init();
</script>

</Layout>

<style is:global>
    /* ============================================
       Auth Page Styles
       Scoped under body.auth-body to prevent leaking
       ============================================ */

    body.auth-body {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 5rem 2rem 2rem;
        padding-top: calc(5rem + env(safe-area-inset-top));
        padding-bottom: calc(2rem + env(safe-area-inset-bottom));
        overflow-x: hidden;
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: var(--bg-card);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 2.5rem 2rem;
        position: relative;
        overflow: hidden;
        margin-top: auto;
        margin-bottom: auto;
    }

    .auth-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 0.25rem;
        letter-spacing: -0.02em;
    }

    .auth-subtitle {
        font-size: 0.9rem;
        text-align: center;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }

    .tab-toggle {
        display: flex;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 100px;
        padding: 4px;
        margin-bottom: 1.5rem;
    }

    .tab-toggle button {
        flex: 1;
        padding: 0.6rem 1rem;
        border: none;
        border-radius: 100px;
        background: transparent;
        color: var(--text-muted);
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.25s ease;
    }

    .tab-toggle button.active {
        background: rgba(255, 255, 255, 0.1);
        color: var(--text-primary);
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .auth-view {
        display: none;
    }

    .auth-view.active {
        display: block;
    }

    .auth-card .message {
        display: none;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
        line-height: 1.4;
    }

    .auth-card .message.visible {
        display: block;
    }

    .auth-card .message.error {
        background: var(--error-subtle, rgba(255, 77, 106, 0.1));
        border: 1px solid rgba(255, 77, 106, 0.2);
        color: var(--error, #ff4d6a);
    }

    .auth-card .message.success {
        background: var(--accent-subtle);
        border: 1px solid rgba(200, 255, 0, 0.2);
        color: var(--accent);
    }

    .auth-card .message .inline-btn {
        background: none;
        border: none;
        color: inherit;
        text-decoration: underline;
        cursor: pointer;
        font-family: inherit;
        font-size: inherit;
        padding: 0;
    }

    .auth-card .divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 1.25rem 0;
        color: var(--text-muted);
        font-size: 0.8rem;
    }

    .auth-card .divider::before,
    .auth-card .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--glass-border);
    }

    .oauth-buttons {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .btn-oauth {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        width: 100%;
        padding: 0.75rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        color: var(--text-primary);
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-oauth:hover {
        background: rgba(255, 255, 255, 0.06);
    }

    .btn-oauth svg {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
    }

    .forgot-link {
        text-align: right;
        margin-top: -0.25rem;
    }

    .forgot-link a {
        color: var(--text-muted);
        font-size: 0.8rem;
        cursor: pointer;
        transition: color 0.2s;
    }

