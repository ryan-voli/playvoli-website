---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Signing In - VOLI"
  description="Completing your sign in to VOLI..."
  minimalFooter
>
    <main class="card">
        <div class="spinner-wrap">
            <div class="loading-spinner"></div>
        </div>
        <h1 class="title">Signing you in...</h1>
        <p class="subtitle" id="status-message">Please wait while we complete your sign in.</p>

        <div id="fallback-actions" class="actions hidden">
            <p class="fallback-text">If the app doesn't open automatically:</p>
            <button id="open-app-btn" class="btn-primary">Open VOLI App</button>
            <a href="/" class="btn-secondary">Return Home</a>
        </div>
    </main>

    <script is:inline slot="scripts">
        function redirectToApp() {
            try {
                var currentUrl = new URL(window.location.href);
                var params = new URLSearchParams();

                if (currentUrl.search) {
                    var queryParams = new URLSearchParams(currentUrl.search);
                    queryParams.forEach(function(value, key) { params.append(key, value); });
                }

                if (currentUrl.hash) {
                    var hashParams = new URLSearchParams(currentUrl.hash.substring(1));
                    hashParams.forEach(function(value, key) { params.append(key, value); });
                }

                var deepLinkUrl = 'voli://oauth/callback?' + params.toString();
                document.getElementById('status-message').textContent = 'Opening VOLI app...';
                window.location.href = deepLinkUrl;

                setTimeout(function() {
                    document.getElementById('status-message').textContent = 'Having trouble opening the app?';
                    document.getElementById('fallback-actions').classList.remove('hidden');
                    var spinnerWrap = document.querySelector('.spinner-wrap');
                    if (spinnerWrap) spinnerWrap.style.display = 'none';

                    document.getElementById('open-app-btn').addEventListener('click', function() {
                        window.location.href = deepLinkUrl;
                    });
                }, 3000);
            } catch (error) {
                document.getElementById('status-message').textContent = 'Something went wrong. Please try again.';
                document.getElementById('fallback-actions').classList.remove('hidden');
                var spinnerWrap = document.querySelector('.spinner-wrap');
                if (spinnerWrap) spinnerWrap.style.display = 'none';
            }
        }

        setTimeout(redirectToApp, 500);
    </script>
</Layout>

<style>
    body {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 5rem 2rem 2rem;
        padding-top: calc(5rem + env(safe-area-inset-top));
        padding-bottom: calc(2rem + env(safe-area-inset-bottom));
    }

    .card {
        width: 100%;
        max-width: 460px;
        background: var(--bg-card);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 3rem 2rem;
        position: relative;
        overflow: hidden;
        text-align: center;
        margin-top: auto;
        margin-bottom: auto;
    }

    .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--glass-highlight), transparent);
    }

    .spinner-wrap {
        margin-bottom: 1.5rem;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top: 3px solid var(--electric-blue);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        margin: 0 auto;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
    }

    .subtitle {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 1rem;
    }

    .hidden { display: none !important; }

    .actions {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
        margin-top: 1rem;
    }

    .fallback-text {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .btn-primary {
        display: inline-block;
        width: 100%;
        padding: 0.875rem 2.5rem;
        background: var(--accent);
        color: #000;
        font-family: inherit;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 24px var(--accent-glow);
        text-decoration: none;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px var(--accent-glow);
    }

    .btn-secondary {
        display: inline-block;
        width: 100%;
        padding: 0.875rem 2.5rem;
        background: transparent;
        color: var(--electric-blue);
        font-family: inherit;
        font-size: 0.95rem;
        font-weight: 600;
        border: 1px solid var(--electric-blue);
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
    }

    .btn-secondary:hover {
        background: rgba(0, 212, 255, 0.1);
        transform: translateY(-2px);
    }

    @media (max-width: 480px) {
        body { padding: 6rem 1rem 1rem; }
        .card { padding: 2rem 1.5rem; border-radius: 20px; }
        .title { font-size: 1.25rem; }
    }
</style>
