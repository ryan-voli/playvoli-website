---
interface Props {
  activePage?: string;
}

const { activePage = '' } = Astro.props;
---

<div class="nav-container">
    <a href="/" class="nav-logo">
        <img src="/images/logo_dark_sm.webp" alt="VOLI">
        <span>Voli</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav desktop-nav">
        <a href="/" class:list={[{ active: activePage === 'home' }]}>Home</a>
        <div class="nav-item-wrap" id="about-trigger">
            <a href="/about" class:list={[{ active: activePage === 'about' || activePage === 'whats-next' }]}>About</a>
            <div class="about-dropdown" id="about-dropdown">
                <a href="/whats-next" class:list={[{ active: activePage === 'whats-next' }]}>What's Next</a>
            </div>
        </div>
        <a href="/contact" class:list={[{ active: activePage === 'contact' }]}>Contact</a>
        <button class="more-btn" id="more-btn">More</button>
    </nav>
    <div class="more-dropdown" id="more-dropdown">
        <div class="more-columns">
            <div class="more-col">
                <div class="more-col-title">Products</div>
                <a href="/mobileapp">Mobile App</a>
                <a href="/discordbot">Discord Bot</a>
                <a href="/redditdailygrid">Reddit Daily Grid</a>
                <a href="/creatorscourt">Creators Court</a>
            </div>
            <div class="more-col">
                <a href="/partners" class="more-col-title-link"><div class="more-col-title">Partners</div></a>
                <a href="/volleytalk">Volley Talk</a>
                <a href="/courtcaptains">Court Captains</a>
                <a href="/mlm">Major League Minute</a>
            </div>
            <div class="more-col">
                <div class="more-col-title">Legal</div>
                <a href="/privacy">Privacy</a>
                <a href="/terms">Terms</a>
            </div>
        </div>
    </div>
    <a href="/dailygrid" class="dg-circle-btn" aria-label="Daily Grid">
        <img src="/images/icons/dailygrid.png" alt="" class="dg-circle-icon">
    </a>
    <div class="download-pill desktop-pill" id="download-pill">Download</div>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <!-- Mobile download icon -->
    <button class="mobile-download-btn" id="download-pill-mobile" aria-label="Download">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
    </button>

    <div id="nav-auth"></div>
</div>

<!-- Mobile dropdown -->
<div class="mobile-menu" id="mobile-menu">
    <nav class="mobile-nav">
        <a href="/" class:list={[{ active: activePage === 'home' }]}>Home</a>
        <a href="/about" class:list={[{ active: activePage === 'about' }]}>About</a>
        <a href="/whats-next" class:list={[{ active: activePage === 'whats-next' }]}>What's Next</a>
        <a href="/contact" class:list={[{ active: activePage === 'contact' }]}>Contact</a>
        <div class="mobile-divider"></div>
        <div class="mobile-section-title">Products</div>
        <a href="/mobileapp">Mobile App</a>
        <a href="/discordbot">Discord Bot</a>
        <a href="/redditdailygrid">Reddit Daily Grid</a>
        <a href="/creatorscourt">Creators Court</a>
        <div class="mobile-section-title">Partners</div>
        <a href="/partners">Partners</a>
        <a href="/volleytalk">Volley Talk</a>
        <a href="/courtcaptains">Court Captains</a>
        <a href="/mlm">Major League Minute</a>
        <div class="mobile-section-title">Legal</div>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
    </nav>
</div>

<script is:inline>
(function() {
    var hamburger = document.getElementById('hamburger');
    var menu = document.getElementById('mobile-menu');
    if (!hamburger || !menu) return;

    hamburger.addEventListener('click', function(e) {
        e.stopPropagation();
        hamburger.classList.toggle('open');
        menu.classList.toggle('open');
    });

    // Close menu when clicking outside
    document.addEventListener('click', function(e) {
        if (!menu.contains(e.target) && !hamburger.contains(e.target)) {
            hamburger.classList.remove('open');
            menu.classList.remove('open');
        }
    });

    // Close menu when clicking a link
    menu.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
            hamburger.classList.remove('open');
            menu.classList.remove('open');
        });
    });

    // Mobile download button — trigger same handler as desktop pill
    var mobileDl = document.getElementById('download-pill-mobile');
    if (mobileDl) {
        mobileDl.addEventListener('click', function() {
            var desktopPill = document.getElementById('download-pill');
            if (desktopPill) desktopPill.click();
        });
    }

    // More dropdown hover
    var moreBtn = document.getElementById('more-btn');
    var moreDd = document.getElementById('more-dropdown');
    var moreTimer = null;
    function showMore() { clearTimeout(moreTimer); moreDd.classList.add('open'); }
    function hideMore() { moreTimer = setTimeout(function() { moreDd.classList.remove('open'); }, 150); }
    if (moreBtn && moreDd) {
        moreBtn.addEventListener('mouseenter', showMore);
        moreBtn.addEventListener('mouseleave', hideMore);
        moreDd.addEventListener('mouseenter', showMore);
        moreDd.addEventListener('mouseleave', hideMore);
    }

    // About dropdown hover
    var aboutTrigger = document.getElementById('about-trigger');
    var aboutDd = document.getElementById('about-dropdown');
    var aboutTimer = null;
    function showAbout() { clearTimeout(aboutTimer); aboutDd.classList.add('open'); }
    function hideAbout() { aboutTimer = setTimeout(function() { aboutDd.classList.remove('open'); }, 150); }
    if (aboutTrigger && aboutDd) {
        aboutTrigger.addEventListener('mouseenter', showAbout);
        aboutTrigger.addEventListener('mouseleave', hideAbout);
        aboutDd.addEventListener('mouseenter', showAbout);
        aboutDd.addEventListener('mouseleave', hideAbout);
    }
})();
</script>

<style>
    .nav-container {
        --nav-h: 44px;
        position: fixed;
        top: 1rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        z-index: 100;
        padding-top: env(safe-area-inset-top);
    }

    .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
    }

    .nav-logo img {
        height: 28px;
        width: auto;
    }

    .nav-logo span {
        color: #ffffff;
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .nav {
        height: var(--nav-h);
        padding: 0.25rem;
        display: flex;
        align-items: stretch;
        justify-content: center;
        gap: 0.25rem;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 22px;
    }

    .nav a {
        color: var(--text-primary);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 0 1.25rem;
        display: flex;
        align-items: center;
        border-radius: 18px;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .nav a:hover {
        background: rgba(255, 255, 255, 0.05);
    }

    .nav a.active {
        background: rgba(255, 255, 255, 0.05);
        font-weight: 650;
    }

    .download-pill {
        height: var(--nav-h);
        padding: 0 1.25rem;
        display: flex;
        align-items: center;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--electric-blue);
        border-radius: 100px;
        cursor: pointer;
        transition: all 0.2s;
        color: #ffffff;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
    }

    .download-pill:hover {
        background: rgba(0, 212, 255, 0.1);
    }

    /* Mobile download icon button */
    .mobile-download-btn {
        display: none;
        align-items: center;
        justify-content: center;
        width: var(--nav-h);
        height: var(--nav-h);
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--electric-blue);
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.2s;
        padding: 0;
    }

    .mobile-download-btn svg {
        width: 20px;
        height: 20px;
        color: #ffffff;
    }

    .mobile-download-btn:hover {
        background: rgba(0, 212, 255, 0.1);
    }

    /* Hamburger button */
    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: var(--nav-h);
        height: var(--nav-h);
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 50%;
        cursor: pointer;
        padding: 10px;
    }

    .hamburger span {
        display: block;
        width: 100%;
        height: 2px;
        background: #ffffff;
        border-radius: 2px;
        transition: all 0.3s ease;
    }

    .hamburger.open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .hamburger.open span:nth-child(2) {
        opacity: 0;
    }

    .hamburger.open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* Mobile menu dropdown */
    .mobile-menu {
        display: none;
        position: fixed;
        top: calc(5rem + env(safe-area-inset-top));
        left: 1rem;
        right: 1rem;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 22px;
        padding: 0.25rem;
        z-index: 99;
        opacity: 0;
        transform: translateY(-10px);
        transition: opacity 0.25s ease, transform 0.25s ease;
        pointer-events: none;
    }

    .mobile-menu.open {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .mobile-nav {
        display: flex;
        flex-direction: column;
    }

    .mobile-nav a {
        color: var(--text-primary);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 0.75rem 1.25rem;
        border-radius: 18px;
        transition: all 0.15s;
        white-space: nowrap;
        width: 100%;
        text-align: center;
    }

    .mobile-nav a:hover,
    .mobile-nav a.active {
        background: rgba(255, 255, 255, 0.05);
    }

    /* Nav auth slot */
    #nav-auth {
        display: flex;
        align-items: center;
    }

    #nav-auth :global(.nav-login-link) {
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        padding: 0.5rem 0.75rem;
        transition: opacity 0.2s;
        white-space: nowrap;
    }

    #nav-auth :global(.nav-login-link:hover) {
        opacity: 0.8;
    }

    #nav-auth :global(.nav-avatar-wrap) {
        position: relative;
    }

    #nav-auth :global(.nav-avatar) {
        display: block;
        width: var(--nav-h);
        height: var(--nav-h);
        border-radius: 50%;
        border: 1px solid var(--accent);
        cursor: pointer;
        object-fit: cover;
        transition: opacity 0.2s;
    }

    #nav-auth :global(.nav-avatar:hover) {
        opacity: 0.85;
    }

    #nav-auth :global(.nav-avatar-fallback) {
        width: var(--nav-h);
        height: var(--nav-h);
        border-radius: 50%;
        border: 1px solid var(--accent);
        background: var(--bg-card);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    #nav-auth :global(.nav-avatar-fallback:hover) {
        opacity: 0.85;
    }

    #nav-auth :global(.avatar-dropdown) {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 22px;
        padding: 0.25rem;
        display: none;
        z-index: 200;
    }

    #nav-auth :global(.avatar-dropdown.open) {
        display: flex;
        flex-direction: column;
    }

    #nav-auth :global(.avatar-dropdown button) {
        height: calc(var(--nav-h) - 0.5rem);
        padding: 0 1.25rem;
        display: flex;
        align-items: center;
        background: transparent;
        border: none;
        color: var(--text-primary);
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 500;
        white-space: nowrap;
        cursor: pointer;
        border-radius: 18px;
        transition: all 0.15s;
    }

    #nav-auth :global(.avatar-dropdown button:hover) {
        background: rgba(255, 255, 255, 0.05);
    }

    #nav-auth :global(.avatar-dropdown button:last-child) {
        color: var(--rose);
    }

    #nav-auth :global(.avatar-dropdown button:last-child:hover) {
        background: rgba(255, 31, 109, 0.1);
    }

    /* About dropdown */
    .nav-item-wrap {
        position: relative;
        display: flex;
        align-items: stretch;
    }

    .about-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%) translateY(-6px);
        background: var(--bg-card);
        -webkit-backdrop-filter: blur(40px);
        backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 22px;
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        visibility: hidden;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
        z-index: 200;
    }

    .about-dropdown.open {
        visibility: visible;
        opacity: 1;
        transform: translateX(-50%) translateY(0);
        pointer-events: auto;
    }

    .about-dropdown a {
        color: var(--text-muted);
        font-size: 0.85rem;
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.15s;
    }

    .about-dropdown a:hover,
    .about-dropdown a.active {
        color: var(--text-primary);
    }

    /* More dropdown */
    .more-btn {
        color: var(--text-primary);
        background: none;
        border: none;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 500;
        padding: 0 1.25rem;
        display: flex;
        align-items: center;
        border-radius: 18px;
        cursor: pointer;
        transition: all 0.15s;
        white-space: nowrap;
    }

    .more-btn:hover {
        background: rgba(255, 255, 255, 0.05);
    }

    .more-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        background: var(--bg-card);
        -webkit-backdrop-filter: blur(40px);
        backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 22px;
        padding: 1.25rem 1.5rem;
        visibility: hidden;
        opacity: 0;
        transform: translateY(-6px);
        pointer-events: none;
        transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
        z-index: 200;
    }

    .more-dropdown.open {
        visibility: visible;
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .more-columns {
        display: flex;
        gap: 2.5rem;
    }

    .more-col {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .more-col-title {
        color: var(--text-primary);
        font-size: 0.75rem;
        font-weight: 650;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.2rem;
    }

    .more-col-title-link {
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .more-col-title-link:hover {
        opacity: 0.8;
    }

    .more-col a {
        color: var(--text-muted);
        font-size: 0.85rem;
        text-decoration: none;
        white-space: nowrap;
        transition: color 0.15s;
    }

    .more-col a:hover {
        color: var(--text-primary);
    }

    /* Mobile section titles & divider */
    .mobile-divider {
        height: 1px;
        background: var(--glass-border);
        margin: 0.25rem 1.25rem;
    }

    .mobile-section-title {
        color: var(--accent);
        font-size: 0.7rem;
        font-weight: 650;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.5rem 1.25rem 0;
        text-align: center;
    }

    /* Daily Grid circle button */
    .dg-circle-btn {
        width: var(--nav-h);
        height: var(--nav-h);
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 50%;
        transition: all 0.2s;
        text-decoration: none;
    }

    .dg-circle-btn:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    .dg-circle-icon {
        width: 22px;
        height: 22px;
        object-fit: contain;
    }

    /* Mobile: show hamburger + download icon, hide desktop elements */
    @media (max-width: 640px) {
        .nav-container {
            width: calc(100% - 2rem);
            left: 1rem;
            transform: none;
        }

        .nav-logo {
            margin-right: auto;
        }

        .desktop-nav,
        .desktop-only {
            display: none !important;
        }

        .desktop-pill {
            display: none !important;
        }

        .mobile-download-btn {
            display: flex;
        }

        .hamburger {
            display: flex;
        }

        .mobile-menu {
            display: block;
        }

        .mobile-nav {
            margin-bottom: 0;
        }
    }
</style>
