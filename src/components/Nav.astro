---
interface Props {
  activePage?: string;
}

const { activePage = '' } = Astro.props;
---

<div class="nav-container">
    <a href="/" class="nav-logo">
        <img src="/images/logo_dark.webp" alt="VOLI">
        <span>Voli</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav desktop-nav">
        <a href="/" class:list={[{ active: activePage === 'home' }]}>Home</a>
        <a href="/about" class:list={[{ active: activePage === 'about' }]}>About</a>
        <a href="/contact" class:list={[{ active: activePage === 'contact' }]}>Contact</a>
    </nav>
    <div class="download-pill desktop-pill" id="download-pill">Download</div>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <!-- Mobile download icon -->
    <button class="mobile-download-btn" id="download-pill-mobile" aria-label="Download">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
    </button>

    <div id="nav-auth"></div>
</div>

<!-- Mobile dropdown -->
<div class="mobile-menu" id="mobile-menu">
    <nav class="mobile-nav">
        <a href="/" class:list={[{ active: activePage === 'home' }]}>Home</a>
        <a href="/about" class:list={[{ active: activePage === 'about' }]}>About</a>
        <a href="/contact" class:list={[{ active: activePage === 'contact' }]}>Contact</a>
    </nav>
</div>

<script is:inline>
(function() {
    var hamburger = document.getElementById('hamburger');
    var menu = document.getElementById('mobile-menu');
    if (!hamburger || !menu) return;

    hamburger.addEventListener('click', function(e) {
        e.stopPropagation();
        hamburger.classList.toggle('open');
        menu.classList.toggle('open');
    });

    // Close menu when clicking outside
    document.addEventListener('click', function(e) {
        if (!menu.contains(e.target) && !hamburger.contains(e.target)) {
            hamburger.classList.remove('open');
            menu.classList.remove('open');
        }
    });

    // Close menu when clicking a link
    menu.querySelectorAll('a').forEach(function(link) {
        link.addEventListener('click', function() {
            hamburger.classList.remove('open');
            menu.classList.remove('open');
        });
    });

    // Mobile download button — trigger same handler as desktop pill
    var mobileDl = document.getElementById('download-pill-mobile');
    if (mobileDl) {
        mobileDl.addEventListener('click', function() {
            var desktopPill = document.getElementById('download-pill');
            if (desktopPill) desktopPill.click();
        });
    }
})();
</script>

<style>
    .nav-container {
        position: fixed;
        top: 1rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        z-index: 100;
        padding-top: env(safe-area-inset-top);
    }

    .nav-logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
    }

    .nav-logo img {
        height: 28px;
        width: auto;
    }

    .nav-logo span {
        color: #ffffff;
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .nav {
        padding: 0.75rem 2rem;
        display: flex;
        justify-content: center;
        gap: 2rem;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 100px;
    }

    .nav a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s;
    }

    .nav a:hover {
        color: var(--text-primary);
    }

    .nav a.active {
        color: var(--text-primary);
    }

    .download-pill {
        padding: 0.75rem 1.25rem;
        display: flex;
        align-items: center;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--electric-blue);
        border-radius: 100px;
        cursor: pointer;
        transition: all 0.2s;
        color: #ffffff;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
    }

    .download-pill:hover {
        background: rgba(0, 212, 255, 0.1);
    }

    /* Mobile download icon button */
    .mobile-download-btn {
        display: none;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--electric-blue);
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.2s;
        padding: 0;
    }

    .mobile-download-btn svg {
        width: 20px;
        height: 20px;
        color: #ffffff;
    }

    .mobile-download-btn:hover {
        background: rgba(0, 212, 255, 0.1);
    }

    /* Hamburger button */
    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 40px;
        height: 40px;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 50%;
        cursor: pointer;
        padding: 10px;
    }

    .hamburger span {
        display: block;
        width: 100%;
        height: 2px;
        background: #ffffff;
        border-radius: 2px;
        transition: all 0.3s ease;
    }

    .hamburger.open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .hamburger.open span:nth-child(2) {
        opacity: 0;
    }

    .hamburger.open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    /* Mobile menu dropdown */
    .mobile-menu {
        display: none;
        position: fixed;
        top: calc(4rem + env(safe-area-inset-top));
        left: 50%;
        transform: translateX(-50%);
        width: calc(100% - 2rem);
        max-width: 360px;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 1.25rem;
        z-index: 99;
        opacity: 0;
        transform: translateX(-50%) translateY(-10px);
        transition: opacity 0.25s ease, transform 0.25s ease;
        pointer-events: none;
    }

    .mobile-menu.open {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
        pointer-events: auto;
    }

    .mobile-nav {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        margin-bottom: 1rem;
    }

    .mobile-nav a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 1rem;
        font-weight: 500;
        padding: 0.75rem 1rem;
        border-radius: 12px;
        transition: all 0.2s;
    }

    .mobile-nav a:hover,
    .mobile-nav a.active {
        color: var(--text-primary);
        background: rgba(255, 255, 255, 0.05);
    }

    /* Nav auth slot */
    #nav-auth {
        display: flex;
        align-items: center;
    }

    #nav-auth :global(.nav-login-link) {
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        padding: 0.5rem 0.75rem;
        transition: opacity 0.2s;
        white-space: nowrap;
    }

    #nav-auth :global(.nav-login-link:hover) {
        opacity: 0.8;
    }

    #nav-auth :global(.nav-avatar-wrap) {
        position: relative;
    }

    #nav-auth :global(.nav-avatar) {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1.5px solid var(--accent);
        cursor: pointer;
        object-fit: cover;
        transition: opacity 0.2s;
    }

    #nav-auth :global(.nav-avatar:hover) {
        opacity: 0.85;
    }

    #nav-auth :global(.nav-avatar-fallback) {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1.5px solid var(--accent);
        background: var(--bg-card);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    #nav-auth :global(.nav-avatar-fallback:hover) {
        opacity: 0.85;
    }

    #nav-auth :global(.avatar-dropdown) {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: rgba(20, 20, 22, 0.95);
        backdrop-filter: blur(40px);
        -webkit-backdrop-filter: blur(40px);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 0.5rem;
        min-width: 140px;
        display: none;
        z-index: 200;
    }

    #nav-auth :global(.avatar-dropdown.open) {
        display: block;
    }

    #nav-auth :global(.avatar-dropdown button) {
        width: 100%;
        padding: 0.6rem 1rem;
        background: transparent;
        border: none;
        color: var(--text-secondary);
        font-family: inherit;
        font-size: 0.85rem;
        text-align: left;
        cursor: pointer;
        border-radius: 8px;
        transition: all 0.15s;
    }

    #nav-auth :global(.avatar-dropdown button:hover) {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-primary);
    }

    /* Mobile: show hamburger + download icon, hide desktop elements */
    @media (max-width: 640px) {
        .desktop-nav,
        .desktop-only {
            display: none !important;
        }

        .desktop-pill {
            display: none !important;
        }

        .mobile-download-btn {
            display: flex;
        }

        .hamburger {
            display: flex;
        }

        .mobile-menu {
            display: block;
        }

        .mobile-nav {
            margin-bottom: 0;
        }
    }
</style>
