---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import QrModal from '../components/QrModal.astro';
import NavAuth from '../components/NavAuth.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  activePage?: string;
  showFooter?: boolean;
  bodyClass?: string;
  /** Set to true for pages that load Supabase SDK themselves */
  skipSupabase?: boolean;
  /** Set to true for pages that don't need the nav auth slot */
  skipNavAuth?: boolean;
}

const {
  title,
  description = 'The ultimate volleyball hub. Fantasy leagues, live stats, game schedules, and more.',
  ogImage = 'https://playvoli.com/images/official_logo_dark_bg.webp',
  ogUrl = 'https://playvoli.com/',
  activePage = '',
  showFooter = true,
  bodyClass = '',
  skipSupabase = false,
  skipNavAuth = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{title}</title>
    <meta name="description" content={description}>

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={ogUrl}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={ogImage}>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content={ogUrl}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImage}>

    <link rel="icon" href="/images/official_logo_dark_bg.webp">

    <!-- Self-hosted Inter font (eliminates 3-hop Google Fonts chain) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
    <style is:inline>
        @font-face {
            font-family: 'Inter';
            font-style: normal;
            font-weight: 300 800;
            font-display: swap;
            src: url('/fonts/inter-latin.woff2') format('woff2');
        }
    </style>

    <!-- Google Analytics + Ads (deferred, non-blocking) -->
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-W77KSNYJG3');
        gtag('config', 'AW-17868194042');
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-W77KSNYJG3"></script>

    <slot name="head" />
</head>
<body class={bodyClass}>
    <Nav activePage={activePage} />

    <slot />

    {showFooter && <Footer />}

    <QrModal />

    <!-- Supabase SDK at end of body (non-render-blocking) -->
    {!skipSupabase && (
        <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    )}

    {!skipNavAuth && !skipSupabase && <NavAuth />}

    <slot name="scripts" />
</body>
</html>
